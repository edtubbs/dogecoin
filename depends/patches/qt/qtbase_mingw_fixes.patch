Guard missing Windows SDK headers in MinGW builds.

MinGW-based toolchains used in CI lack newer Windows SDK headers, which
breaks Qt 6 builds in the network information plugin and D3D12 RHI
implementation. Guard these headers and constants so the affected code is
skipped when they are unavailable.

--- a/qtbase/src/gui/rhi/qrhid3d12_p.h
+++ b/qtbase/src/gui/rhi/qrhid3d12_p.h
@@ -19,11 +19,21 @@
 
 #include <optional>
 #include <array>
 
-#include <d3d12.h>
-#include <d3d12sdklayers.h>
-#include <dxgi1_6.h>
-#include <dcomp.h>
-
-#include "D3D12MemAlloc.h"
+#if defined(__has_include)
+#  if __has_include(<d3d12.h>)
+#    include <d3d12.h>
+#    include <d3d12sdklayers.h>
+#    include <dxgi1_6.h>
+#    include <dcomp.h>
+#    include "D3D12MemAlloc.h"
+#  endif
+#else
+#  include <d3d12.h>
+#  include <d3d12sdklayers.h>
+#  include <dxgi1_6.h>
+#  include <dcomp.h>
+#  include "D3D12MemAlloc.h"
+#endif
 
 // ID3D12Device2 and ID3D12GraphicsCommandList1 and types and enums introduced
 // with those are hard requirements now. These should be declared in any
 // moderately recent d3d12.h, but if it is an SDK from before Windows 10
--- a/qtbase/src/plugins/networkinformation/networklistmanager/qnetworklistmanagerevents.cpp
+++ b/qtbase/src/plugins/networkinformation/networklistmanager/qnetworklistmanagerevents.cpp
@@ -12,6 +12,10 @@
 
 #include <mutex>
 
+#ifndef NLM_INTERNET_CONNECTIVITY_WEBHIJACK
+#define NLM_INTERNET_CONNECTIVITY_WEBHIJACK 0
+#endif
+
 #if QT_CONFIG(cpp_winrt)
 #include <QtCore/private/qt_winrtbase_p.h>
 
